<Window x:Class="TrainRzdApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление поездами РЖД" 
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen">

    <DockPanel>
  
        <Border DockPanel.Dock="Top" Background="#1E3A8A" Padding="10" Margin="0,0,0,5">
            <TextBlock Text="🚂 ОАО РЖД - Система управления поездами и бригадами" 
                       FontSize="18" FontWeight="Bold" Foreground="White"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Вкладки занимают всё остальное место -->
        <TabControl Margin="5">

            <!-- Вкладка 1: Поезда -->
            <TabItem Header="🚆 Поезда">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="5">
                        <Button x:Name="btnRefreshTrains" Content="Обновить" Width="90" Margin="2" 
                                Click="BtnRefreshTrains_Click" Background="#4CAF50" Foreground="White"/>
                        <Button x:Name="btnAddTrain" Content="Добавить" Width="90" Margin="2" 
                                Click="BtnAddTrain_Click" Background="#2196F3" Foreground="White"/>
                        <Button x:Name="btnEditTrain" Content="Редактировать" Width="90" Margin="2" 
                                Click="BtnEditTrain_Click" Background="#FF9800" Foreground="White"/>
                        <Button x:Name="btnDeleteTrain" Content="Удалить" Width="90" Margin="2" 
                                Click="BtnDeleteTrain_Click" Background="#F44336" Foreground="White"/>
                    </StackPanel>

                    <DataGrid x:Name="dgTrains" Grid.Row="1" Margin="5" 
                              AutoGenerateColumns="True" SelectionMode="Single" 
                              IsReadOnly="True" AlternatingRowBackground="#F0F0F0"/>
                </Grid>
            </TabItem>

            <!-- Вкладка 2: Бригады -->
            <TabItem Header="👥 Бригады">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="5">
                        <Button x:Name="btnRefreshCrews" Content="Обновить" Width="90" Margin="2" 
                                Click="BtnRefreshCrews_Click" Background="#4CAF50" Foreground="White"/>
                        <Button x:Name="btnAddCrew" Content="Добавить" Width="90" Margin="2" 
                                Click="BtnAddCrew_Click" Background="#2196F3" Foreground="White"/>
                        <Button x:Name="btnEditCrew" Content="Редактировать" Width="90" Margin="2" 
                                Click="BtnEditCrew_Click" Background="#FF9800" Foreground="White"/>
                        <Button x:Name="btnDeleteCrew" Content="Удалить" Width="90" Margin="2" 
                                Click="BtnDeleteCrew_Click" Background="#F44336" Foreground="White"/>
                    </StackPanel>

                    <DataGrid x:Name="dgCrews" Grid.Row="1" Margin="5" 
                              AutoGenerateColumns="True" SelectionMode="Single" 
                              IsReadOnly="True" AlternatingRowBackground="#F0F0F0"/>
                </Grid>
            </TabItem>

            <!-- Вкладка 3: Назначения -->
            <TabItem Header="📋 Назначения">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="5">
                        <Button x:Name="btnRefreshAssignments" Content="Обновить" Width="90" Margin="2" 
                                Click="BtnRefreshAssignments_Click" Background="#4CAF50" Foreground="White"/>
                        <Button x:Name="btnAddAssignment" Content="Назначить" Width="90" Margin="2" 
                                Click="BtnAddAssignment_Click" Background="#2196F3" Foreground="White"/>
                        <Button x:Name="btnDeleteAssignment" Content="Отменить" Width="90" Margin="2" 
                                Click="BtnDeleteAssignment_Click" Background="#F44336" Foreground="White"/>
                    </StackPanel>

                    <DataGrid x:Name="dgAssignments" Grid.Row="1" Margin="5" 
                              AutoGenerateColumns="True" SelectionMode="Single" 
                              IsReadOnly="True" AlternatingRowBackground="#F0F0F0"/>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>