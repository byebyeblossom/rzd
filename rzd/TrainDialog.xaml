<Window x:Class="TrainRzdApp.TrainDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Поезд" Height="465" Width="450" WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Номер поезда:" FontWeight="Bold" Margin="5"/>
        <TextBox x:Name="txtNumber" Grid.Row="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="2" Text="Тип поезда:" FontWeight="Bold" Margin="5"/>
        <ComboBox x:Name="cmbType" Grid.Row="3" Margin="5" Height="30">
            <ComboBoxItem Content="Пассажирский"/>
            <ComboBoxItem Content="Грузовой"/>
            <ComboBoxItem Content="Скорый"/>
        </ComboBox>

        <TextBlock Grid.Row="4" Text="Макс. скорость (км/ч):" FontWeight="Bold" Margin="5"/>
        <TextBox x:Name="txtSpeed" Grid.Row="5" Margin="5" Height="30"/>

        <TextBlock Grid.Row="6" Text="Вес (тонн):" FontWeight="Bold" Margin="5"/>
        <TextBox x:Name="txtWeight" Grid.Row="7" Margin="5" Height="30"/>

        <TextBlock Grid.Row="8" Text="Статус:" FontWeight="Bold" Margin="5"/>
        <ComboBox x:Name="cmbStatus" Grid.Row="9" Margin="5" Height="30">
            <ComboBoxItem Content="Активен"/>
            <ComboBoxItem Content="В ремонте"/>
        </ComboBox>

        <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
            <Button x:Name="btnOk" Content="OK" Width="80" Height="35" Margin="10" 
                    Click="BtnOk_Click" Background="#4CAF50" Foreground="White"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="80" Height="35" Margin="10" 
                    Click="BtnCancel_Click" Background="#F44336" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>